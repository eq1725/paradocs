# Operator-curated phenomenon images staged for adoption.
# Files in this directory are picked up by:
#   tsx scripts/adopt-phenomena-images.ts --batch
# They get re-encoded into hero/card/thumb webp and uploaded to the
# phenomena-images Supabase bucket — the originals don't need to ship
# in the repo. BUT we keep the empty category-folder scaffolding so
# /source-images/<category>/ exists in fresh clones; only image and
# sidecar files are ignored.
/source-images/**/*.jpg
/source-images/**/*.jpeg
/source-images/**/*.png
/source-images/**/*.webp
/source-images/**/*.avif
/source-images/**/*.json

# Working files - do not commit
*.sql
*.patch
*.bundle
*.bundle.lock
*.tar.gz
public/_push_data.json
BATCH*.md
SESSION_PROMPT*.md
SESSION_PROTOCOL.md
ENRICHMENT_GUIDE.md
PARADOCS_PROJECT_NOTES.md
ParaDocs_QA_QC_Report.md
HANDOFF_MAP.md
sql_chunks/
sql_small_chunks/
Adlet-profile.png
research-hub-files.tar.gz

# Allow supabase migrations despite the *.sql blanket ignore above
!supabase/migrations/*.sql

# Orchestrator + ingestion run artifacts — generated locally
outputs/*.log
outputs/orchestrator-state.json
outputs/arctic-shift-*.log

# V11.17.4 — Homepage showcase recordings.
# Raw .mov source files are kept locally for re-encoding; only the
# optimized .mp4 / .webm derivatives go into the repo + CDN.
public/showcase/*.mov
public/showcase/*.MOV

# V11.17.39 — operational scratch files that accumulate during mass-
# ingestion + script runs. None of these belong in version control.
# Note: .gitignore does NOT support inline comments — patterns must be
# alone on the line. Comments go above the patterns.

# per-run logs (embed-backfill-full.log, image-adoption.log, etc.)
*.log

# ad-hoc backups of edited files
*.bak
.env.local.bak

# one-shot debugging scripts I write inline
scripts/.tmp-*.mjs

# diagnostic scratch (_debug-*, _check-*, etc.)
scripts/_*.ts

# mass-ingestion checkpoint files
outputs/*-state.json

# smoke test artifacts
b1-5-smoke-test-*.json

# script-run output CSVs (kept locally for review)
phenomena-emptiness.csv
merge-low-volume-review.csv
missing-images.csv

# tilde-suffixed backup files some editors leave behind
*~
