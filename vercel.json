{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "functions": {
    "src/pages/api/admin/ingest.ts": { "maxDuration": 300 },
    "src/pages/api/admin/reingest.ts": { "maxDuration": 300 },
    "src/pages/api/admin/ai/*.ts": { "maxDuration": 300 },
    "src/pages/api/cron/*.ts": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/weekly-deep-scan",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/admin/leads/select-today",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/push/send-daily-lead",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/signal-alerts",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/signal-digest-email",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/match-circles-curate",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/refresh-global-save-counts",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/reconcile-phenomena-counts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/process-account-deletions",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/transcribe-videos",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reconcile-mux",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/audit-taxonomy",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/recompute-standing",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/refresh-trending-phenomena",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/recompute-dossiers",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/evaluate-watchlists",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/send-watchlist-digest",
      "schedule": "0 9 * * 0"
    }
  ]
}

