{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "functions": {
    "src/pages/api/admin/ingest.ts": { "maxDuration": 300 },
    "src/pages/api/admin/reingest.ts": { "maxDuration": 300 },
    "src/pages/api/admin/ai/*.ts": { "maxDuration": 300 },
    "src/pages/api/cron/*.ts": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/weekly-deep-scan",
      "schedule": "0 6 * * 0"
    }
  ]
}
