{
  "name": "paradocs",
  "version": "1.0.0",
  "description": "The world's largest database of paranormal phenomena",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "node scripts/typecheck-gate.js",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "node scripts/typecheck-gate.js",
    "typecheck:full": "tsc --noEmit -p tsconfig.json",
    "seed": "node scripts/seed-data.js",
    "batch-import": "npx ts-node scripts/batch-import-reddit.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "cap:build": "PARADOCS_CAPACITOR=1 next build && next export -o out",
    "cap:sync": "npm run cap:build && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
