# ============================================
# ParaDocs Environment Variables
# ============================================
# SECURITY: Never commit actual values to version control!
# Copy this file to .env.local and fill in real values.

# ============================================
# Supabase Configuration (Required)
# ============================================
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key - KEEP SECRET, server-side only
# Used for admin operations, cron jobs, and bypassing RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Site Configuration
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Beta Site Protection
# ============================================
# Set to 'true' to enable HTTP Basic Auth protection for the entire site
BETA_PROTECTION_ENABLED=false

# SECURITY: Use strong, unique credentials in production!
# Generate with: openssl rand -base64 32
BETA_AUTH_USERNAME=your-beta-username
BETA_AUTH_PASSWORD=your-secure-password-minimum-20-chars

# ============================================
# Cron Job Authentication
# ============================================
# Secret for authenticating cron job requests
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ============================================
# AI/External Services (Required for AI features)
# ============================================
# Anthropic API key — primary AI provider (Claude) for chat, insights, pattern narratives
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI API key — used for vector embeddings (text-embedding-3-small) and as chat fallback
# REQUIRED for: semantic search, RAG pipeline, pattern detection via embeddings
OPENAI_API_KEY=your-openai-api-key

# ============================================
# YouTube Data API v3 (Required for YouTube ingestion)
# ============================================
# Get from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your project
YOUTUBE_API_KEY=your-youtube-api-key

# ============================================
# Mapbox (Optional - for geocoding)
# ============================================
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# ============================================
# MapTiler (Required - for map basemap tiles)
# ============================================
# Get from https://cloud.maptiler.com/account/keys/
# Set domain restrictions: your-domain.com, localhost
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-api-key
