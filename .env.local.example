# Paradocs — local-development env template
# Copy to .env.local and fill in real values. Do not commit .env.local.
#
# This file shadows .env.example to add Lab-tier-3 / Tier 3D feature
# flags that don't belong in the public template yet.

# ============================================
# Supabase
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Site / auth
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=your-cron-secret-here

# ============================================
# AI / external services
# ============================================
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
YOUTUBE_API_KEY=your-youtube-api-key
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-api-key

# ============================================
# Stripe (Tier 2A pricing surfaces)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# ============================================
# Ingestion + AI cost caps
# ============================================
USE_CONSOLIDATED_AI=true
PARADOCS_MASS_INGEST_DAILY_CAP=200
PARADOCS_AUTO_CLASSIFY=true
PARADOCS_AUTO_BLURB=true

# ============================================
# V11.17.74 — Tier 3D feature flags (Sentiment baseline + endpoints)
# ============================================
# When true, surfaces the corpus-comparative sentiment baseline line on
# the n=1 dossier (LAB_PANEL_REVIEW_V3 §5). Off by default — founder
# enables when the soft-launch eval set passes.
HINTS_ENABLE_SENTIMENT=false

# When true, the consolidated AI prompt appends the sentiment block so
# newly ingested reports get sentiment scored in the same Haiku call
# (zero marginal Anthropic cost beyond the system-prompt addendum, since
# the response stays one JSON document). Off by default until the
# founder approves the output quality on a sample batch. Independent of
# HINTS_ENABLE_SENTIMENT — backfilling data and rendering it to users
# are separate flips.
INCLUDE_SENTIMENT=false
